# =========================================
# Fast2Mine QA - Variáveis Sensíveis
# =========================================
# Copie este arquivo para .env e preencha com valores reais.
# O arquivo .env NÃO é commitado (está no .gitignore).
#
# Em CI/CD, configure como GitHub Secrets:
#   Repository -> Settings -> Secrets and variables -> Actions
# =========================================

# QA1
QA1_USERNAME=qa1.user@fast2mine.com
QA1_PASSWORD=changeme

# QA2
QA2_USERNAME=qa2.user@fast2mine.com
QA2_PASSWORD=changeme

# QA3
QA3_USERNAME=qa3.user@fast2mine.com
QA3_PASSWORD=changeme

# Appium (mobile)
APPIUM_URL=http://127.0.0.1:4723

# Slack notifications (opcional)
SLACK_WEBHOOK_URL=
